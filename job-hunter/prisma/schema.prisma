generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id             String    @id @default(cuid())
  externalId     String    @unique
  title          String
  company        String
  location       String
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?   @default("INR")
  platform       Platform
  url            String
  description    String?   @db.Text
  isQuickApply   Boolean   @default(false)
  isRemote       Boolean   @default(false)
  employmentType String?
  postedAt       DateTime?
  fetchedAt      DateTime  @default(now())
  matchScore     Int?

  applications Application[]
  queueItems   AutoApplyQueue[]
  aiContent    AiContent?
}

model Application {
  id        String            @id @default(cuid())
  jobId     String
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    ApplicationStatus @default(SAVED)
  appliedAt DateTime?
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  followUpReminders FollowUpReminder[]
  calendarEvents    CalendarEvent[]

  @@unique([jobId])
}

model AutoApplyQueue {
  id          String      @id @default(cuid())
  jobId       String
  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status      QueueStatus @default(PENDING)
  scheduledAt DateTime    @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime    @default(now())
}

model AiContent {
  id                String   @id @default(cuid())
  jobId             String   @unique
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  coverLetter       String?  @db.Text
  tailoredResume    String?  @db.Text
  atsScore          Int?
  atsKeywords       Json?
  outreachEmail     String?  @db.Text
  negotiationScript String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FollowUpReminder {
  id            String         @id @default(cuid())
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          ReminderType
  status        ReminderStatus @default(PENDING)
  dueAt         DateTime
  sentAt        DateTime?
  createdAt     DateTime       @default(now())

  @@unique([applicationId, type])
}

model InterviewPrep {
  id        String   @id @default(cuid())
  company   String
  role      String
  questions Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@unique([company, role])
}

model CalendarEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  googleEventId String
  htmlLink      String
  scheduledAt   DateTime
  createdAt     DateTime    @default(now())

  @@unique([applicationId, scheduledAt])
}

model LinkedInConnection {
  id         String   @id @default(cuid())
  name       String
  title      String?
  company    String?
  profileUrl String   @unique
  createdAt  DateTime @default(now())

  @@index([company])
}

model UserSettings {
  id                   String    @id @default("singleton")
  resumeText           String?   @db.Text
  digestEmail          String?
  reminderDays         Int       @default(7)
  scrapePending        Boolean   @default(false)
  lastScrapedAt        DateTime?
  naukriScrapePending  Boolean   @default(false)
  calendarToken        String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

enum Platform {
  LINKEDIN
  NAUKRI
  INDEED
  GLASSDOOR
  OTHER
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum QueueStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ReminderType {
  INITIAL
  FOLLOWUP_2
  FOLLOWUP_3
}

enum ReminderStatus {
  PENDING
  SENT
  SKIPPED
}
